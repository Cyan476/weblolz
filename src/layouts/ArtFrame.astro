---
---
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link href="https://fonts.googleapis.com/css2?family=Comic+Relief&display=swap" rel="stylesheet">
    </head>
    <body>
        <style is:global>
            body {
                margin: 0;
                background-color: #ffffff;
                color: #1a191d;
                font-family: 'Comic Relief', cursive;
                height: 100vh;
                display: grid;
                grid-template-rows: auto auto 1fr;
                justify-items: center;
                align-content: start;
            }
            
            .nav-container {
    width: 100% !important;
    display: flex;
    justify-content: center;
    gap: 20px;
    padding: 10px 0;
    border-bottom: 2px solid #000000;
}

.muzik-player {
    width: 80% !important; /* Makes it look like a centered card */
    margin: 20px auto !important;
    border: 2px solid #000000;
    padding: 20px;
    text-align: center;
}

.astro-route-announcer, 
    main, 
    div {
        max-width: none !important;
        width: 100% !important;
    }

    h1 {
        font-size: 8vw !important; /* Forces font to scale relative to screen */
        line-height: 1 !important;
        margin: 1 !important;
        padding: 1 !important;
        text-align: center !important;
    }

    h2 {
        font-size: 6vw !important; /* Forces font to scale relative to screen */
        line-height: 1 !important;
        margin: 1 !important;
        padding: 1 !important;
        text-align: center !important;
    }

    h3 {
        font-size: 5vw !important; /* Forces font to scale relative to screen */
        line-height: 1 !important;
        margin: 1 !important;
        padding: 1 !important;
        text-align: center !important;
    }

    h4 {
        font-size: 3vw !important; /* Forces font to scale relative to screen */
        line-height: 1 !important;
        margin: 1 !important;
        padding: 1 !important;
    }



            hr {
                grid-row: 2;
                width: 100vw;
                border: 0;
                border-top: 2px solid #000000;
                margin: 20px 0; 
            }
        </style>

        <div class="content-area">
            <slot />
        </div>
    </body>
</html>