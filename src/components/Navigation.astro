---
// src/components/Navigation.astro
const links = [
    { name: 'HOME', url: '/' },
    { name: 'MUZIK', url: '/muzik' },
    { name: 'POZTZ', url: '/poztz' },
    { name: 'PORJEKTS', url: '/porjekts' }
];
---
<nav>
    <div class="nav-links">
        {links.map(link => (
            <a href={link.url}>
                {link.name}
            </a>
        ))}
    </div>
    <div class="nav-bar"></div>
</nav>

<style>
    .nav-links {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }
    .nav-bar {
        border-bottom: 4px dashed var(--z-magenta);
        margin-bottom: 2rem;
    }
</style>